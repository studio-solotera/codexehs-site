# Codex EHS - variables d'environnement
# Copier ce fichier en .env (pour le dev local) ou definir les memes
# variables dans Cloudflare Pages > Settings > Environment variables.
#
# IMPORTANT: prefixer obligatoirement PUBLIC_ pour qu'Astro expose la
# variable au navigateur. Sinon elle reste cote serveur uniquement.

# --- Lemon Squeezy (Merchant of Record) ---
# Store identifier (slug du store, visible dans l'URL des produits LS)
PUBLIC_LEMON_STORE=codexehs

# Variant IDs des produits (a remplir une fois les produits crees dans LS)
# Plan d'Action EHS Dynamique - 89 EUR
PUBLIC_LEMON_VARIANT_PLAN_ACTION=
# Registre AT/Incidents - 119 EUR (bientot)
PUBLIC_LEMON_VARIANT_REGISTRE_AT=
# Tableau de Bord EHS - 99 EUR (bientot)
PUBLIC_LEMON_VARIANT_TABLEAU_BORD=
# Pack Audit ISO 45001 - 249 EUR (bientot)
PUBLIC_LEMON_VARIANT_PACK_AUDIT=
# Kit DUERP Industriel - 199 EUR (bientot)
PUBLIC_LEMON_VARIANT_KIT_DUERP=

# --- URL canonique site (override de astro.config.mjs si besoin) ---
PUBLIC_SITE_URL=https://codexehs.com

# --- Contact ---
PUBLIC_CONTACT_EMAIL=contact@codexehs.com
