---
// src/components/sales/SalesHero.astro
// Hero conversion de la page de vente Plan d’Action EHS.
// Promesse + sous-promesse + visuel produit + CTA + signaux confiance.

import LemonCheckoutButton from "../LemonCheckoutButton.astro";

interface Props {
  variantId?: string;
  price?: string;
}

const { variantId = "", price = "89 €" } = Astro.props;
---

<section class="hero" aria-labelledby="hero-title">
  <div class="hero__inner">
    <div class="hero__copy">
      <span class="eyebrow">
        <span class="dot"></span> Plan d’Action EHS Dynamique
      </span>

      <h1 id="hero-title" class="hero__title">
        Le Plan d’Action EHS qui se gère <em>tout seul</em>.
      </h1>

      <p class="hero__subtitle">
        Excel premium. Dashboard temps réel. Multi-pays francophone.
        Conçu par un EHS Manager d’usine pour les EHS solos qui en ont
        marre des 3 tableaux Excel à recoller le vendredi soir.
      </p>

      <ul class="hero__bullets">
        <li><strong>500 actions</strong> pré-formatées, 25 colonnes métier</li>
        <li><strong>6 KPI + 6 graphiques</strong> mis à jour en temps réel</li>
        <li><strong>8 pays</strong> francophones (FR · BE · CH · LU · QC · MA · TN · DZ)</li>
        <li><strong>Audit-ready</strong> en 48 h — ISO 45001 / 14001 compatible</li>
      </ul>

      <div class="hero__cta">
        <LemonCheckoutButton variantId={variantId} label={`Acheter — ${price}`} />
        <a href="#apercu" class="btn btn--ghost">Voir l’aperçu produit</a>
      </div>

      <ul class="hero__trust">
        <li>
          <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true">
            <path fill="currentColor" d="M12 1l9 4v6c0 5.55-3.84 10.74-9 12-5.16-1.26-9-6.45-9-12V5l9-4zm-1.5 14.5l7-7-1.4-1.4-5.6 5.6L7.9 10.1l-1.4 1.4 4 4z"/>
          </svg>
          Paiement sécurisé Stripe
        </li>
        <li>
          <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true">
            <path fill="currentColor" d="M5 20h14v-2H5v2zM19 9h-4V3H9v6H5l7 7 7-7z"/>
          </svg>
          Livraison instantanée
        </li>
        <li>
          <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true">
            <path fill="currentColor" d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 17h-2v-2h2v2zm2.07-7.75l-.9.92C13.45 12.9 13 13.5 13 15h-2v-.5c0-1.1.45-2.1 1.17-2.83l1.24-1.26c.37-.36.59-.86.59-1.41 0-1.1-.9-2-2-2s-2 .9-2 2H8c0-2.21 1.79-4 4-4s4 1.79 4 4c0 .88-.36 1.68-.93 2.25z"/>
          </svg>
          Support 30 jours
        </li>
        <li>
          <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true">
            <path fill="currentColor" d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
          </svg>
          Aperçu avant achat
        </li>
      </ul>
    </div>

    <figure class="hero__visual">
      <img
        src="/visuels/02-dashboard-kpi.svg"
        alt="Dashboard EHS Codex avec 6 KPI temps réel, donut de répartition statut et graphique mensuel création vs clôture"
        loading="eager"
        decoding="async"
      />
      <figcaption>Dashboard — temps réel, 6 KPI + 6 graphiques</figcaption>
    </figure>
  </div>
</section>

<style>
  .hero {
    background:
      radial-gradient(ellipse at 80% -10%, rgba(242,107,31,0.08), transparent 50%),
      radial-gradient(ellipse at 0% 100%, rgba(30,69,116,0.06), transparent 50%),
      var(--c-bg);
    padding: clamp(48px, 6vw, 96px) 0 clamp(40px, 5vw, 72px);
    border-bottom: 1px solid var(--c-line);
  }
  .hero__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 clamp(20px, 4vw, 48px);
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.05fr);
    gap: clamp(32px, 5vw, 72px);
    align-items: center;
  }
  @media (max-width: 920px) {
    .hero__inner { grid-template-columns: 1fr; }
  }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--c-primary-700);
    margin-bottom: 24px;
  }
  .eyebrow .dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: var(--c-action);
    box-shadow: 0 0 0 4px rgba(242,107,31,0.18);
  }

  .hero__title {
    font-family: 'Inter Variable', Inter, system-ui, sans-serif;
    font-size: clamp(36px, 5.2vw, 60px);
    font-weight: 800;
    line-height: 1.04;
    letter-spacing: -0.025em;
    color: var(--c-primary-900);
    margin: 0 0 20px;
  }
  .hero__title em {
    font-style: normal;
    color: var(--c-action);
    position: relative;
    white-space: nowrap;
  }
  .hero__title em::after {
    content: '';
    position: absolute;
    left: 0; right: 0; bottom: -6px;
    height: 4px;
    background: var(--c-action);
    opacity: 0.18;
    border-radius: 4px;
  }

  .hero__subtitle {
    font-size: clamp(16px, 1.6vw, 19px);
    line-height: 1.55;
    color: var(--c-ink-600);
    margin: 0 0 28px;
    max-width: 56ch;
  }

  .hero__bullets {
    list-style: none;
    padding: 0;
    margin: 0 0 32px;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 10px 28px;
  }
  .hero__bullets li {
    position: relative;
    padding-left: 26px;
    font-size: 14.5px;
    color: var(--c-ink-900);
    line-height: 1.5;
  }
  .hero__bullets li::before {
    content: '';
    position: absolute;
    left: 0; top: 6px;
    width: 16px; height: 16px;
    background: var(--c-action);
    mask: url("data:image/svg+xml,%3Csvg viewBox='0 0 24 24' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath fill='black' d='M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z'/%3E%3C/svg%3E") no-repeat center / contain;
    -webkit-mask: url("data:image/svg+xml,%3Csvg viewBox='0 0 24 24' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath fill='black' d='M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z'/%3E%3C/svg%3E") no-repeat center / contain;
  }

  .hero__cta {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-bottom: 28px;
  }
  .hero__cta :global(.btn) { font-size: 16px; padding: 14px 24px; }

  .hero__trust {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 14px 24px;
    color: var(--c-ink-600);
    font-size: 13px;
  }
  .hero__trust li {
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  .hero__trust svg { color: var(--c-success); }

  .hero__visual {
    margin: 0;
    background: var(--c-bg);
    border: 1px solid var(--c-line);
    border-radius: 14px;
    padding: 12px;
    box-shadow:
      0 1px 2px rgba(15,42,71,0.04),
      0 16px 40px -16px rgba(15,42,71,0.18),
      0 32px 80px -24px rgba(15,42,71,0.12);
    transform: rotate(-0.4deg);
    position: relative;
  }
  .hero__visual::before {
    content: '';
    position: absolute;
    inset: -3px;
    border-radius: 16px;
    background: linear-gradient(135deg, var(--c-primary-900), var(--c-action));
    z-index: -1;
    opacity: 0.07;
  }
  .hero__visual img {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 8px;
  }
  .hero__visual figcaption {
    font-size: 12px;
    color: var(--c-ink-300);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    text-align: center;
    margin-top: 12px;
    font-weight: 600;
  }
</style>
