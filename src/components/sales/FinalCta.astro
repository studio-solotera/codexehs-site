---
// src/components/sales/FinalCta.astro
// CTA final + récap prix complet.
// Reprend les signaux de confiance du hero pour clore la vente.

import LemonCheckoutButton from "../LemonCheckoutButton.astro";

interface Props {
  variantId?: string;
  price?: string;
}

const { variantId = "", price = "89 €" } = Astro.props;

const recap = [
  "Fichier Excel maître XLSX (500 lignes, 25 colonnes, 4591 formules)",
  "Dashboard 6 KPI + 6 graphiques + matrice criticité",
  "Planning 12 mois + multi-pays 8 codes francophones",
  "Guide PDF 10 pages + fichier démo pré-rempli",
  "Mises à jour mineures 12 mois + support email 30 jours",
];

const trust = [
  { label: "Paiement sécurisé Lemon Squeezy", icon: "lock" },
  { label: "Livraison instantanée par email", icon: "bolt" },
  { label: "Support 30 jours inclus", icon: "headset" },
];
---

<section class="final" aria-labelledby="final-title">
  <div class="final__inner">
    <div class="final__card">
      <span class="eyebrow">
        <span class="dot"></span> Le moment de décider
      </span>
      <h2 id="final-title" class="final__title">
        Lundi matin, tu peux ouvrir un dashboard à jour
        <em>au lieu de fabriquer le rapport pour la direction</em>.
      </h2>
      <p class="final__lead">
        Le Plan d’Action EHS Dynamique, c’est l’outil que j’aurais
        voulu trouver quand j’ai pris mon poste de Responsable EHS
        solo. Je l’ai construit, affiné, durci pendant deux ans. Il
        est à toi pour 89 € — moins qu’une demi-journée de ton temps
        chargé.
      </p>

      <div class="final__cta-row">
        <LemonCheckoutButton
          variantId={variantId}
          label={`Acheter pour ${price}`}
          fullWidth={false}
        />
        <div class="final__price">
          <span class="final__price-num">{price}</span>
          <span class="final__price-label">paiement unique, TTC</span>
        </div>
      </div>

      <ul class="final__trust">
        {trust.map((t) => (
          <li>
            {t.icon === "lock" && (
              <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <rect
                  x="5"
                  y="11"
                  width="14"
                  height="9"
                  rx="2"
                  stroke="currentColor"
                  stroke-width="1.7"
                />
                <path
                  d="M8 11V8a4 4 0 1 1 8 0v3"
                  stroke="currentColor"
                  stroke-width="1.7"
                  stroke-linecap="round"
                />
              </svg>
            )}
            {t.icon === "bolt" && (
              <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path
                  d="M13 3 5 14h6l-2 7 8-11h-6l2-7Z"
                  stroke="currentColor"
                  stroke-width="1.7"
                  stroke-linejoin="round"
                />
              </svg>
            )}
            {t.icon === "headset" && (
              <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path
                  d="M4 14v-2a8 8 0 0 1 16 0v2M4 14v3a2 2 0 0 0 2 2h1v-7H6a2 2 0 0 0-2 2Zm16 0v3a2 2 0 0 1-2 2h-1v-7h1a2 2 0 0 1 2 2Z"
                  stroke="currentColor"
                  stroke-width="1.7"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
              </svg>
            )}
            <span>{t.label}</span>
          </li>
        ))}
      </ul>

      <div class="final__recap" aria-label="Récapitulatif de la commande">
        <h3 class="final__recap-title">Récapitulatif</h3>
        <ul class="final__recap-list">
          {recap.map((r) => (
            <li>
              <svg viewBox="0 0 20 20" fill="none" aria-hidden="true">
                <path
                  d="M4 10.5l4 4 8-9"
                  stroke="currentColor"
                  stroke-width="2.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
              </svg>
              <span>{r}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>

<style>
  .final {
    padding: clamp(64px, 9vw, 112px) 0;
    background: var(--c-primary-900);
    position: relative;
    overflow: hidden;
  }

  .final::before,
  .final::after {
    content: "";
    position: absolute;
    width: 600px;
    height: 600px;
    border-radius: 50%;
    filter: blur(120px);
    pointer-events: none;
    opacity: 0.4;
  }

  .final::before {
    top: -200px;
    left: -200px;
    background: rgba(242, 107, 31, 0.15);
  }

  .final::after {
    bottom: -200px;
    right: -200px;
    background: rgba(30, 69, 116, 0.4);
  }

  .final__inner {
    max-width: 820px;
    margin: 0 auto;
    padding: 0 clamp(20px, 4vw, 40px);
    position: relative;
    z-index: 1;
  }

  .final__card {
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 16px;
    padding: clamp(32px, 5vw, 56px);
    backdrop-filter: blur(8px);
  }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: "JetBrains Mono Variable", monospace;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.7);
    margin-bottom: 16px;
  }

  .eyebrow .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--c-action);
  }

  .final__title {
    font-size: clamp(26px, 3.6vw, 38px);
    font-weight: 700;
    color: #fff;
    line-height: 1.2;
    margin: 0 0 18px;
    letter-spacing: -0.02em;
  }

  .final__title em {
    font-style: normal;
    color: var(--c-action);
    background: linear-gradient(
      transparent 70%,
      rgba(242, 107, 31, 0.25) 70%
    );
    padding: 0 2px;
  }

  .final__lead {
    font-size: 16px;
    color: rgba(255, 255, 255, 0.75);
    line-height: 1.65;
    margin: 0 0 32px;
  }

  .final__cta-row {
    display: flex;
    align-items: center;
    gap: 24px;
    flex-wrap: wrap;
    margin-bottom: 28px;
  }

  .final__price {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .final__price-num {
    font-family: "JetBrains Mono Variable", monospace;
    font-size: 26px;
    font-weight: 700;
    color: #fff;
    line-height: 1;
    letter-spacing: -0.02em;
  }

  .final__price-label {
    font-size: 12px;
    color: rgba(255, 255, 255, 0.55);
    font-family: "JetBrains Mono Variable", monospace;
    letter-spacing: 0.04em;
  }

  .final__trust {
    list-style: none;
    padding: 0;
    margin: 0 0 32px;
    display: flex;
    gap: 24px;
    flex-wrap: wrap;
  }

  .final__trust li {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13.5px;
    color: rgba(255, 255, 255, 0.7);
  }

  .final__trust svg {
    width: 17px;
    height: 17px;
    color: var(--c-action);
    flex-shrink: 0;
  }

  .final__recap {
    background: rgba(0, 0, 0, 0.25);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 10px;
    padding: 22px 24px;
  }

  .final__recap-title {
    font-family: "JetBrains Mono Variable", monospace;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.55);
    margin: 0 0 14px;
  }

  .final__recap-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .final__recap-list li {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: 14px;
    color: #fff;
    line-height: 1.5;
  }

  .final__recap-list svg {
    width: 16px;
    height: 16px;
    color: var(--c-success);
    flex-shrink: 0;
    margin-top: 2px;
  }

  @media (max-width: 560px) {
    .final__cta-row {
      flex-direction: column;
      align-items: stretch;
    }
    .final__price {
      align-items: center;
    }
  }
</style>
