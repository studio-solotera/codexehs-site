---
/**
 * Layout Base - shell HTML commun + SEO meta + Open Graph
 * Charge global.css, expose <slot/> pour le contenu, monte header+footer.
 *
 * Props :
 *   - title : titre de la page (concatene avec |  Codex EHS)
 *   - description : meta description
 *   - canonical : URL canonique (optionnel, fallback = Astro.url)
 *   - ogImage : image OG (optionnel, fallback = /og-default.png)
 *   - jsonLd : objet JSON-LD a injecter (Product, FAQPage, ...)
 *   - noindex : true pour bloquer indexation (page merci, 404)
 */
import { SITE } from '@data/site';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import '@styles/global.css';

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  jsonLd?: object | object[];
  noindex?: boolean;
}

const {
  title,
  description = SITE.description,
  canonical,
  ogImage = '/og-default.png',
  jsonLd,
  noindex = false,
} = Astro.props;

const pageTitle = title === SITE.name ? title : `${title} | ${SITE.name}`;
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, SITE.url).toString();
const ogImageUrl = new URL(ogImage, SITE.url).toString();
const jsonLdArray = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
---

<!doctype html>
<html lang={SITE.language}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="generator" content={Astro.generator} />

    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    {noindex && <meta name="robots" content="noindex, nofollow" />}

    {/* Favicon : monogramme SVG (vectoriel, leger) + fallback PNG */}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    {/* Open Graph */}
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="fr_FR" />
    <meta property="og:site_name" content={SITE.name} />

    {/* Twitter / X */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    {/* Theme color (mobile address bar) */}
    <meta name="theme-color" content="#0F2A47" />
    <meta name="color-scheme" content="light" />

    {/* JSON-LD structured data (Organization global + page-specific) */}
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'Organization',
        name: SITE.name,
        url: SITE.url,
        logo: `${SITE.url}/logos/wordmark.svg`,
        email: SITE.email,
        founder: {
          '@type': 'Person',
          name: SITE.author.name,
          jobTitle: SITE.author.role,
        },
      })}
    />

    {jsonLdArray.map((obj) => (
      <script type="application/ld+json" set:html={JSON.stringify(obj)} />
    ))}

    {/* Preconnect Lemon Squeezy (le checkout chargera assets.lemonsqueezy.com) */}
    <link rel="preconnect" href="https://assets.lemonsqueezy.com" crossorigin />
  </head>

  <body>
    <a href="#main" class="sr-only">Aller au contenu</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />

    {/* Lemon Squeezy overlay - charge en defer pour ne pas bloquer le rendu */}
    <script src="https://assets.lemonsqueezy.com/lemon.js" defer></script>
  </body>
</html>
