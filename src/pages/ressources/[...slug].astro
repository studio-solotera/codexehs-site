---
// src/pages/ressources/[...slug].astro
// Gabarit d'un article de la section Ressources.
//
// Layout : Base.astro. On lui passe `title` NU (Base ajoute « | <nom du site> »),
// `description`, `canonical`, `ogImage` (chemin relatif -> Base le resout en absolu)
// et `jsonLd` (Base injecte Article + BreadcrumbList + son Organization global).
// hreflang fr/x-default gere dans Base : rien a faire ici.
//
// Astro 5 : render(entry) depuis 'astro:content'. Sous Astro 4, remplacer par
// `const { Content } = await entry.render();` et `entry.id` -> `entry.slug` (cf. README).

import Base from '../../layouts/Base.astro';
import ArticleMeta from '../../components/ressources/ArticleMeta.astro';
import ArticleCta from '../../components/ressources/ArticleCta.astro';
import RelatedArticles from '../../components/ressources/RelatedArticles.astro';
import { getCollection, render } from 'astro:content';
import '../../styles/ressources.css';

const SITE_URL = 'https://codexehs.com';

export async function getStaticPaths() {
  // Publication planifiee : seules les pages des articles dont la date est
  // atteinte sont generees. Les articles futurs n'existent pas encore sur le
  // site -> absents du build, du maillage interne et du sitemap. Un rebuild
  // quotidien les fait apparaitre a echeance (.github/workflows/daily-rebuild.yml).
  const maintenant = Date.now();
  const entries = await getCollection('ressources', ({ data }) => !data.draft && data.date.valueOf() <= maintenant);
  return entries.map((entry) => ({ params: { slug: entry.id }, props: { entry, entries } }));
}

const { entry, entries } = Astro.props;
const { Content } = await render(entry);

// Estimation du temps de lecture a partir du corps brut.
const motsCorps = (entry.body ?? '').trim().split(/\s+/).filter(Boolean).length;

// --- Maillage interne ---
const memeGrappe = entries.filter((e) => e.data.grappe === entry.data.grappe && e.id !== entry.id);

let liens: { href: string; titre: string; description: string; estPilier: boolean }[] = [];
if (entry.data.type === 'satellite') {
  // Satellite : pilier de rattachement en tete + autres satellites de la grappe.
  const pilier = memeGrappe.find((e) => e.id === entry.data.pilier) ?? memeGrappe.find((e) => e.data.type === 'pilier');
  if (pilier) liens.push({ href: `/ressources/${pilier.id}`, titre: pilier.data.titre, description: pilier.data.description, estPilier: true });
  liens.push(
    ...memeGrappe
      .filter((e) => e.data.type === 'satellite')
      .map((e) => ({ href: `/ressources/${e.id}`, titre: e.data.titre, description: e.data.description, estPilier: false }))
  );
} else {
  // Pilier : tous les satellites de la grappe.
  liens = memeGrappe
    .filter((e) => e.data.type === 'satellite')
    .map((e) => ({ href: `/ressources/${e.id}`, titre: e.data.titre, description: e.data.description, estPilier: false }));
}

const titreMaillage = entry.data.type === 'satellite' ? 'À lire aussi dans cette série' : 'Les articles de cette série';

// --- Canonical + OG + JSON-LD ---
const canonical = `${SITE_URL}/ressources/${entry.id}`;
const ogImageRel = entry.data.ogImage ?? '/og/ressources.png'; // relatif pour Base
const ogImageAbs = `${SITE_URL}${ogImageRel}`;                  // absolu pour le JSON-LD

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: entry.data.titre,
  description: entry.data.description,
  datePublished: entry.data.date.toISOString(),
  dateModified: (entry.data.maj ?? entry.data.date).toISOString(),
  author: { '@type': 'Person', name: entry.data.auteur },
  publisher: {
    '@type': 'Organization',
    name: 'CODEX EHS',
    url: SITE_URL,
    logo: { '@type': 'ImageObject', url: ogImageAbs },
  },
  mainEntityOfPage: { '@type': 'WebPage', '@id': canonical },
  image: ogImageAbs,
  inLanguage: 'fr-FR',
  isPartOf: { '@type': 'WebSite', name: 'CODEX EHS', url: SITE_URL },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Accueil', item: `${SITE_URL}/` },
    { '@type': 'ListItem', position: 2, name: 'Ressources', item: `${SITE_URL}/ressources` },
    { '@type': 'ListItem', position: 3, name: entry.data.titre, item: canonical },
  ],
};
---

<Base
  title={entry.data.titre}
  description={entry.data.description}
  canonical={canonical}
  ogImage={ogImageRel}
  jsonLd={[articleSchema, breadcrumbSchema]}
>
  <article class="res-prose-wrap">
    <nav class="res-breadcrumb" aria-label="Fil d’Ariane">
      <a href="/">Accueil</a> / <a href="/ressources">Ressources</a> /
      <span aria-current="page">{entry.data.titre}</span>
    </nav>

    <header>
      <span class="res-article__eyebrow">
        {entry.data.type === 'pilier' ? 'Guide complet' : 'Article'}
      </span>
      <h1 class="res-article__title">{entry.data.titre}</h1>
      <ArticleMeta auteur={entry.data.auteur} date={entry.data.date} maj={entry.data.maj} motsCorps={motsCorps} />
    </header>

    <div class="res-prose">
      <Content />
    </div>

    <ArticleCta produit={entry.data.produit} />

    <RelatedArticles titre={titreMaillage} liens={liens} />
  </article>
</Base>
