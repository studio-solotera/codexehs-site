---
// src/pages/produits/plan-action-ehs.astro
// Page de vente complète du Plan d’Action EHS Dynamique.
// Assemble les 10 composants de la section sales/.
// CODEX EHS — page de vente Plan d’Action.

import Base from "../../layouts/Base.astro";
import SalesHero from "../../components/sales/SalesHero.astro";
import Personas from "../../components/sales/Personas.astro";
import PainPoints from "../../components/sales/PainPoints.astro";
import Solution from "../../components/sales/Solution.astro";
import ProductPreview from "../../components/sales/ProductPreview.astro";
import WhatIsIncluded from "../../components/sales/WhatIsIncluded.astro";
import FaqSales from "../../components/sales/FaqSales.astro";
import Guarantee from "../../components/sales/Guarantee.astro";
import FinalCta from "../../components/sales/FinalCta.astro";
import Testimonials from "../../components/sales/Testimonials.astro";
import { SITE } from "../../config/site";

// Variable Lemon Squeezy (à renseigner après KYB validé).
const variantId = import.meta.env.LEMON_VARIANT_PLAN_ACTION ?? "";
const price = "89 €";

// JSON-LD Product + Offer pour le SEO.
const productJsonLd = {
  "@context": "https://schema.org",
  "@type": "Product",
  name: "Plan d’Action EHS Dynamique",
  description:
    "Plan d’action EHS dynamique pour Excel : 500 lignes, 4591 formules, " +
    "dashboard KPI auto-calculé, planning 12 mois glissants, matrice de " +
    "criticité 5x5, adaptation 8 pays francophones. Compatible Excel 2016 " +
    "à 365, Windows et Mac.",
  image: `${SITE.url}/visuels/02-dashboard-kpi.svg`,
  brand: {
    "@type": "Brand",
    name: "CODEX EHS",
  },
  offers: {
    "@type": "Offer",
    url: `${SITE.url}/produits/plan-action-ehs`,
    priceCurrency: "EUR",
    price: "89.00",
    availability: "https://schema.org/InStock",
    priceValidUntil: "2027-12-31",
    seller: { "@type": "Organization", name: "CODEX EHS" },
    hasMerchantReturnPolicy: {
      "@type": "MerchantReturnPolicy",
      applicableCountry: ["FR", "BE", "CH", "LU", "QC", "MA", "TN", "DZ"],
      returnPolicyCategory: "https://schema.org/MerchantReturnNotPermitted",
    },
  },
};

// JSON-LD FAQ pour le SEO.
const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "Sur quelle version d’Excel le Plan d’Action EHS fonctionne-t-il ?",
      acceptedAnswer: {
        "@type": "Answer",
        text:
          "Excel 2016, 2019, 2021 et Microsoft 365, sur Windows comme sur " +
          "Mac. Le fichier n’utilise que des fonctions standard (INDEX/EQUIV, " +
          "SOMMEPROD, NB.SI.ENS) et aucune fonction réservée à l’abonnement " +
          "365 : une licence Office déjà installée suffit.",
      },
    },
    {
      "@type": "Question",
      name: "Un seul fichier suffit-il pour gérer plusieurs pays ?",
      acceptedAnswer: {
        "@type": "Answer",
        text:
          "Oui. Un seul fichier maître couvre 8 pays francophones (FR, BE, " +
          "CH, LU, QC, MA, TN, DZ). Il suffit de changer une cellule dans " +
          "l’onglet Démarrer ici : références réglementaires et vocabulaire " +
          "EHS s’adaptent.",
      },
    },
    {
      "@type": "Question",
      name: "Et si le fichier ne me convient pas ?",
      acceptedAnswer: {
        "@type": "Answer",
        text:
          "Tu vois l’aperçu détaillé du fichier (six onglets, vraies " +
          "formules, vrai dashboard) avant d’acheter. Le produit étant un " +
          "contenu numérique livré immédiatement, le droit de rétractation " +
          "ne s’applique pas (art. L221-28 du Code de la consommation), donc " +
          "pas de remboursement de confort. Tout souci technique réel " +
          "(fichier non conforme, lien défaillant, double débit) est corrigé " +
          "ou remboursé de bonne foi via contact@codexehs.com. Support email " +
          "30 jours inclus.",
      },
    },
  ],
};

const title = "Plan d’Action EHS Dynamique — Excel audit-ready · CODEX EHS";
const description =
  "Plan d’action EHS multi-pays clé en main pour Excel (2016 à 365). " +
  "Dashboard KPI auto-calculé, planning 12 mois, matrice criticité 5×5. " +
  "89 € TTC, livraison instantanée, aperçu complet avant achat.";
---

<Base
  title={title}
  description={description}
  jsonLd={[productJsonLd, faqJsonLd]}
>
  <main>
    <SalesHero variantId={variantId} price={price} />
    <Personas />
    <PainPoints />
    <Solution />
    <ProductPreview />
    <WhatIsIncluded />
    <Guarantee />
    <FaqSales />
    <Testimonials />
    <FinalCta variantId={variantId} price={price} />
  </main>
</Base>
